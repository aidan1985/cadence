# Cadence configuration. Copy to `.env` (gitignored) and fill in.

# The single repo to ingest, as "owner/repo".
GITHUB_REPO=vercel/next.js

# GitHub token. Optional for public repos (raises the rate limit from 60 to
# 5000 req/hr); required for private repos. A fine-grained PAT with read-only
# "Pull requests" + "Contents" access is sufficient.
# GITHUB_TOKEN=ghp_xxx

# Where the SQLite data store lives. Defaults to data/cadence.db.
# CADENCE_DB_PATH=data/cadence.db
